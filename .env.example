# Copy to .env for local dev:  cp .env.example .env
# On Render, set these in the dashboard instead (never commit real .env).

# ── Application ───────────────────────────────────
APP_NAME=olistay-ai
APP_ENV=development
APP_PORT=8000

# ── Database (PostgreSQL) ─────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=olistay_db
DB_USER=postgres
DB_PASSWORD=

# ── LLM Provider: ollama | claude | openai | gemini | groq ──
LLM_PROVIDER=groq

# ── Ollama (local only — not used on hosted deploy) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── API keys (fill your own; leave blank if unused) ──
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Scoring Engine Weights (must sum to 1.0) ──────
WEIGHT_FINANCIAL=0.30
WEIGHT_GOAL_ALIGNMENT=0.25
WEIGHT_HOUSEHOLD=0.15
WEIGHT_LIFESTYLE=0.15
WEIGHT_SAFETY=0.10
WEIGHT_STABILITY=0.05

# ── Financial Thresholds ──────────────────────────
MAX_RENT_TO_INCOME_RATIO=0.30
MIN_EMERGENCY_FUND_MONTHS=3

# ── Spring Boot (for CORS / internal communication) ──
SPRING_BOOT_BASE_URL=http://localhost:8082

# ── ChromaDB ─────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=financial_knowledge

# ── ML Models Storage ─────────────────────────────
MODELS_DIR=./data/models
